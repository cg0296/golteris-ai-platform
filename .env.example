# Golteris — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to source control — it is git-ignored.

# Database connection string.
# Local dev: postgresql://golteris:golteris@localhost:5432/golteris
# Render: provided automatically by the managed Postgres add-on.
DATABASE_URL=postgresql://golteris:golteris@localhost:5432/golteris

# Anthropic API key for Claude. Stored in Render's secret manager in production.
# See REQUIREMENTS.md §2.5 and §5 C5 for cost cap requirements.
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Daily and monthly cost caps for Anthropic API usage (in USD).
# Hard stop when reached — no further Claude calls until the cap resets.
ANTHROPIC_DAILY_COST_CAP=50.00
ANTHROPIC_MONTHLY_COST_CAP=500.00
