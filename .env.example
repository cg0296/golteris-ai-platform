# Golteris — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to source control — it is git-ignored.

# Database connection string.
# Local dev: postgresql://golteris:golteris@localhost:5432/golteris
# Render: provided automatically by the managed Postgres add-on.
DATABASE_URL=postgresql://golteris:golteris@localhost:5432/golteris

# --- LLM Provider API Keys ---
# The system is LLM-agnostic. Set keys for whichever providers you want to use.
# At least one provider key is required. See REQUIREMENTS.md §2.5.

# Anthropic (Claude) — default provider
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT-4o, GPT-4.1) — optional, for provider flexibility
OPENAI_API_KEY=sk-xxxxx

# Default LLM provider and model. Used when no per-agent override is configured.
# Options: "anthropic" or "openai"
LLM_DEFAULT_PROVIDER=anthropic
LLM_DEFAULT_MODEL=claude-sonnet-4-6

# --- LLM Cost Caps ---
# Applies across ALL providers combined. Hard stop when reached.
LLM_DAILY_COST_CAP=20.00
LLM_MONTHLY_COST_CAP=100.00

# --- Email Ingestion ---
# The system is email-provider-agnostic. See REQUIREMENTS.md §2.6.
# If IMAP is configured, the worker polls the real mailbox.
# If not, it falls back to the seed file provider (seed/beltmann/).

# IMAP settings (works with Gmail, Outlook, Yahoo, any IMAP server)
# Gmail: imap.gmail.com (use app password, not regular password)
# Outlook: outlook.office365.com
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# Seed file directory (used when IMAP is not configured)
SEED_EMAIL_DIR=seed/beltmann/shipper_emails

# Worker settings
WORKER_POLL_INTERVAL=10
WORKER_MAX_JOBS_PER_CYCLE=5

# --- Render API (for provisioning script only) ---
RENDER_API_KEY=rnd_xxxxx
